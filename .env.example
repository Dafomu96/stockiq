# ─────────────────────────────────────────────────────────────────────────────
# StockIQ — Environment variable reference
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.
#
# All variables are optional: sensible defaults are defined in
# config/settings.py via Pydantic Settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data ──────────────────────────────────────────────────────────────────────
# Default yfinance period for price history
# STOCKIQ_DEFAULT_PERIOD=1y

# ── Cache ─────────────────────────────────────────────────────────────────────
# Local directory for JSON cache files
STOCKIQ_CACHE_DIR=.cache

# Cache TTLs in seconds (defaults: prices 24h, fundamentals 24h, rf-rate 7d)
# STOCKIQ_CACHE_TTL_PRICES=86400
# STOCKIQ_CACHE_TTL_FUNDAMENTALS=86400
# STOCKIQ_CACHE_TTL_RISK_FREE_RATE=604800

# ── API ───────────────────────────────────────────────────────────────────────
# Rate limiting (slowapi format: "N/period")
STOCKIQ_API_RATE_LIMIT=10/minute

# ── Fundamental analysis ──────────────────────────────────────────────────────
# Risk-free rate fallback if FRED is unreachable (decimal, e.g. 0.045 = 4.5%)
STOCKIQ_RISK_FREE_RATE_FALLBACK=0.045

# Expected market return for CAPM (decimal)
# STOCKIQ_MARKET_RETURN=0.10

# ── Scoring weights ───────────────────────────────────────────────────────────
# Must sum to 1.0
# STOCKIQ_WEIGHT_FUNDAMENTAL=0.50
# STOCKIQ_WEIGHT_TECHNICAL=0.50
